[7.0703, "o", "\u001b[H\u001b[2J loader.py\nsrc/configlib/loader.py\n\u2502 1   \"\"\"Configuration file loading utilities.\"\"\"\n    1\n    2 from __future__ import annotations\n    3\n    4 import json\n    5 from pathlib import Path\n    6 from typing import Any\n    7\n    8 from configlib.schema import validate\n    9\n_  10\n\u2502  11 def load_config(path: str | Path) -> dict[str, Any]:\n   12     \"\"\"Load and parse a configuration file.\"\"\"\n   13     path = Path(path)\n   14     fmt = detect_format(path)\n   15     raw = path.read_text(encoding=\"utf-8\")\n   16\n   17     if fmt == \"json\":\n   18         data = json.loads(raw)\n   19     elif fmt == \"yaml\":\n   20         data = load_yaml(raw)\n   21     else:\n   22         raise ValueError(f\"Unsupported format: {fmt}\")\n   23\n   24     validate(data)\n   25     return data\n   26\n   27\n   28 def detect_format(path: str | Path) -> str:\n   29     \"\"\"Detect config file format from extension.\"\"\"\n   30     suffix = Path(path).suffix.lower()\n Normal  \ue725 main \uf4d2 ~2 -1  src/configlib/loader.py                                 python utf-8[unix] 1.09KiB  1|44\u2502 1|43\n\n"]
