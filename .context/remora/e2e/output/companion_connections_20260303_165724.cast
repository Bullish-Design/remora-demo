[31.1519, "o", "\u001b[H\u001b[2J\u001b[38;2;174;174;174m\u001b[48;2;8;9;13m processor.py \u001b[1m\u001b[38;2;162;215;255m\u001b[48;2;15;17;21m test_processor.py \u001b[0m\u001b[38;2;174;174;174m\u001b[48;2;8;9;13m\r\n\u001b[48;2;0;43;69m/home/andrew/Documents/Projects/remora/remora_demo/companion/examples/tests/test_\u001b[38;2;163;210;245m\u001b[48;2;6;17;27m\u250c\u001b[38;2;49;50;53mr\u001b[1m\u001b[38;2;163;210;245mNotifications\u001b[0m\u001b[38;2;49;50;53m\u001b[48;2;6;17;27m \u001b[38;2;163;210;245m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\r\n\u001b[38;2;162;215;255m\u001b[48;2;15;17;21m\u2506 \u001b[1m1   \u001b[0m\u001b[38;2;169;224;183m\u001b[48;2;45;47;52m\"\"\"Tests\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mfor\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mthe\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mdata\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mprocessor\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mmodule.\"\"\"\u001b[38;2;208;208;208m                                 \u001b[38;2;167;214;249m\u001b[48;2;17;18;22m\u2502\u001b[38;2;204;201;249m16:57:55\u001b[38;2;58;58;61m \u001b[38;2;204;201;249m\u2502\u001b[38;2;58;58;61m \u001b[38;2;204;201;249m[Companion]\u001b[38;2;58;58;61m \u001b[38;2;204;201;249mSidebar\u001b[38;2;58;58;61m \u001b[38;2;204;201;249mclosed\u001b[38;2;167;214;249m\u2502\r\n\u001b[38;2;162;215;255m\u001b[48;2;15;17;21m\u2506 \u001b[38;2;75;78;83m  1 \u001b[38;2;208;208;208m                                                                           \u001b[38;2;167;214;249m\u001b[48;2;9;11;15m\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\r\n\u001b[38;2;214;212;151m\u001b[48;2;15;17;21mW \u001b[38;2;75;78;83m  2 \u001b[1m\u001b[38;2;204;201;255mimport\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[4m\u001b[38;2;140;140;140mpytest\u001b[0m\u001b[38;2;208;208;208m\u001b[48;2;15;17;21m\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m  3 \u001b[1m\u001b[38;2;204;201;255mfrom\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[38;2;214;212;151msrc\u001b[38;2;247;197;154m.\u001b[38;2;214;212;151mprocessor\u001b[38;2;75;78;83m \u001b[1m\u001b[38;2;204;201;255mimport\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[38;2;208;208;208mDataProcessor\u001b[38;2;247;197;154m,\u001b[38;2;75;78;83m \u001b[38;2;208;208;208mDataRecord\u001b[38;2;247;197;154m,\u001b[38;2;75;78;83m \u001b[38;2;208;208;208mcalculate_statistics\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m  4 \u001b[38;2;208;208;208m\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m  5 \u001b[38;2;208;208;208m\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m  6 \u001b[1m\u001b[38;2;208;208;208mclass\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[38;2;208;208;208mTestDataProcessor\u001b[38;2;247;197;154m:\u001b[38;2;208;208;208m\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m  7     \u001b[38;2;169;224;183m\"\"\"Test\u001b[38;2;75;78;83m \u001b[38;2;169;224;183msuite\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mfor\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mDataProcessor\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mclass.\"\"\"\u001b[38;2;208;208;208m\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m  8 \u001b[38;2;208;208;208m\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m  9     \u001b[1m\u001b[38;2;208;208;208mdef\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[38;2;162;215;255mtest_load_data_returns_records\u001b[38;2;247;197;154m(\u001b[38;2;143;225;226mself\u001b[38;2;247;197;154m):\u001b[38;2;208;208;208m\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 10         \u001b[38;2;169;224;183m\"\"\"Load\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mdata\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mshould\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mreturn\u001b[38;2;75;78;83m \u001b[38;2;169;224;183ma\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mlist\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mof\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mDataRecord\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mobjects.\"\"\"\u001b[38;2;208;208;208m\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 11         \u001b[38;2;208;208;208mprocessor\u001b[38;2;75;78;83m \u001b[38;2;208;208;208m=\u001b[38;2;75;78;83m \u001b[38;2;143;225;226mDataProcessor\u001b[38;2;247;197;154m()\u001b[38;2;208;208;208m\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 12         \u001b[38;2;208;208;208mrecords\u001b[38;2;75;78;83m \u001b[38;2;208;208;208m=\u001b[38;2;75;78;83m \u001b[38;2;208;208;208mprocessor\u001b[38;2;247;197;154m.\u001b[38;2;162;215;255mload_data\u001b[38;2;247;197;154m(\u001b[38;2;169;224;183m\"dummy_source\"\u001b[38;2;247;197;154m)\u001b[38;2;208;208;208m\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 13 \u001b[38;2;208;208;208m\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 14         \u001b[1m\u001b[38;2;208;208;208massert\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[38;2;143;225;226mlen\u001b[38;2;247;197;154m(\u001b[38;2;208;208;208mrecords\u001b[38;2;247;197;154m)\u001b[38;2;75;78;83m \u001b[38;2;208;208;208m>\u001b[38;2;75;78;83m \u001b[38;2;240;189;232m0\u001b[38;2;208;208;208m\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 15         \u001b[1m\u001b[38;2;208;208;208massert\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[38;2;143;225;226mall\u001b[38;2;247;197;154m(\u001b[38;2;143;225;226misinstance\u001b[38;2;247;197;154m(\u001b[38;2;208;208;208mr\u001b[38;2;247;197;154m,\u001b[38;2;75;78;83m \u001b[38;2;208;208;208mDataRecord\u001b[38;2;247;197;154m)\u001b[38;2;75;78;83m \u001b[1m\u001b[38;2;208;208;208mfor\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[38;2;208;208;208mr\u001b[38;2;75;78;83m \u001b[1m\u001b[38;2;208;208;208min\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[38;2;208;208;208mrecords\u001b[38;2;247;197;154m)\u001b[38;2;208;208;208m\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 16 \u001b[38;2;208;208;208m\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 17     \u001b[1m\u001b[38;2;208;208;208mdef\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[38;2;162;215;255mtest_validate_record_passes_by_default\u001b[38;2;247;197;154m(\u001b[38;2;143;225;226mself\u001b[38;2;247;197;154m):\u001b[38;2;208;208;208m\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 18         \u001b[38;2;169;224;183m\"\"\"With\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mno\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mvalidators,\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mall\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mrecords\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mshould\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mpass.\"\"\"\u001b[38;2;208;208;208m\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 19         \u001b[38;2;208;208;208mprocessor\u001b[38;2;75;78;83m \u001b[38;2;208;208;208m=\u001b[38;2;75;78;83m \u001b[38;2;143;225;226mDataProcessor\u001b[38;2;247;197;154m()\u001b[38;2;208;208;208m\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 20         \u001b[38;2;208;208;208mrecord\u001b[38;2;75;78;83m \u001b[38;2;208;208;208m=\u001b[38;2;75;78;83m \u001b[38;2;143;225;226mDataRecord\u001b[38;2;247;197;154m(\u001b[38;2;204;201;255mid\u001b[38;2;208;208;208m=\u001b[38;2;169;224;183m\"1\"\u001b[38;2;247;197;154m,\u001b[38;2;75;78;83m \u001b[38;2;204;201;255mname\u001b[38;2;208;208;208m=\u001b[38;2;169;224;183m\"test\"\u001b[38;2;247;197;154m,\u001b[38;2;75;78;83m \u001b[38;2;204;201;255mvalue\u001b[38;2;208;208;208m=\u001b[38;2;240;189;232m10.0\u001b[38;2;247;197;154m)\u001b[38;2;208;208;208m\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 21 \u001b[38;2;20