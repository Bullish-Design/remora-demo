75;78;83m \u001b[38;2;208;208;208mcalculate_statistics\u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m  4 \u001b[38;2;208;208;208m                                                                         \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m  5 \u001b[38;2;208;208;208m                                                                         \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m  6 \u001b[1m\u001b[38;2;208;208;208mclass\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[38;2;208;208;208mTestDataProcessor\u001b[38;2;247;197;154m:\u001b[38;2;208;208;208m                                                 \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m  7     \u001b[38;2;169;224;183m\"\"\"Test\u001b[38;2;75;78;83m \u001b[38;2;169;224;183msuite\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mfor\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mDataProcessor\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mclass.\"\"\"\u001b[38;2;208;208;208m                            \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m  8 \u001b[38;2;208;208;208m                                                                         \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m  9     \u001b[1m\u001b[38;2;208;208;208mdef\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[38;2;162;215;255mtest_load_data_returns_records\u001b[38;2;247;197;154m(\u001b[38;2;143;225;226mself\u001b[38;2;247;197;154m):\u001b[38;2;208;208;208m                            \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 10         \u001b[38;2;169;224;183m\"\"\"Load\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mdata\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mshould\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mreturn\u001b[38;2;75;78;83m \u001b[38;2;169;224;183ma\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mlist\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mof\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mDataRecord\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mobjects.\"\"\"\u001b[38;2;208;208;208m      \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 11         \u001b[38;2;208;208;208mprocessor\u001b[38;2;75;78;83m \u001b[38;2;208;208;208m=\u001b[38;2;75;78;83m \u001b[38;2;143;225;226mDataProcessor\u001b[38;2;247;197;154m()\u001b[38;2;208;208;208m                                      \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 12         \u001b[38;2;208;208;208mrecords\u001b[38;2;75;78;83m \u001b[38;2;208;208;208m=\u001b[38;2;75;78;83m \u001b[38;2;208;208;208mprocessor\u001b[38;2;247;197;154m.\u001b[38;2;162;215;255mload_data\u001b[38;2;247;197;154m(\u001b[38;2;169;224;183m\"dummy_source\"\u001b[38;2;247;197;154m)\u001b[38;2;208;208;208m                    \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 13 \u001b[38;2;208;208;208m                                                                         \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 14         \u001b[1m\u001b[38;2;208;208;208massert\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[38;2;143;225;226mlen\u001b[38;2;247;197;154m(\u001b[38;2;208;208;208mrecords\u001b[38;2;247;197;154m)\u001b[38;2;75;78;83m \u001b[38;2;208;208;208m>\u001b[38;2;75;78;83m \u001b[38;2;240;189;232m0\u001b[38;2;208;208;208m                                          \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 15         \u001b[1m\u001b[38;2;208;208;208massert\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[38;2;143;225;226mall\u001b[38;2;247;197;154m(\u001b[38;2;143;225;226misinstance\u001b[38;2;247;197;154m(\u001b[38;2;208;208;208mr\u001b[38;2;247;197;154m,\u001b[38;2;75;78;83m \u001b[38;2;208;208;208mDataRecord\u001b[38;2;247;197;154m)\u001b[38;2;75;78;83m \u001b[1m\u001b[38;2;208;208;208mfor\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[38;2;208;208;208mr\u001b[38;2;75;78;83m \u001b[1m\u001b[38;2;208;208;208min\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[38;2;208;208;208mrecords\u001b[38;2;247;197;154m)\u001b[38;2;208;208;208m           \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 16 \u001b[38;2;208;208;208m                                                                         \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 17     \u001b[1m\u001b[38;2;208;208;208mdef\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[38;2;162;215;255mtest_validate_record_passes_by_default\u001b[38;2;247;197;154m(\u001b[38;2;143;225;226mself\u001b[38;2;247;197;154m):\u001b[38;2;208;208;208m                    \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 18         \u001b[38;2;169;224;183m\"\"\"With\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mno\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mvalidators,\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mall\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mrecords\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mshould\u001b[38;2;75;78;83m \u001b[38;2;169;224;183mpass.\"\"\"\u001b[38;2;208;208;208m               \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 19         \u001b[38;2;208;208;208mprocessor\u001b[38;2;75;78;83m \u001b[38;2;208;208;208m=\u001b[38;2;75;78;83m \u001b[38;2;143;225;226mDataProcessor\u001b[38;2;247;197;154m()\u001b[38;2;208;208;208m                                      \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 20         \u001b[38;2;208;208;208mrecord\u001b[38;2;75;78;83m \u001b[38;2;208;208;208m=\u001b[38;2;75;78;83m \u001b[38;2;143;225;226mDataRecord\u001b[38;2;247;197;154m(\u001b[38;2;204;201;255mid\u001b[38;2;208;208;208m=\u001b[38;2;169;224;183m\"1\"\u001b[38;2;247;197;154m,\u001b[38;2;75;78;83m \u001b[38;2;204;201;255mname\u001b[38;2;208;208;208m=\u001b[38;2;169;224;183m\"test\"\u001b[38;2;247;197;154m,\u001b[38;2;75;78;83m \u001b[38;2;204;201;255mvalue\u001b[38;2;208;208;208m=\u001b[38;2;240;189;232m10.0\u001b[38;2;247;197;154m)\u001b[38;2;208;208;208m             \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 21 \u001b[38;2;208;208;208m                                                                         \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 22         \u001b[1m\u001b[38;2;208;208;208massert\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[38;2;208;208;208mprocessor\u001b[38;2;247;197;154m.\u001b[38;2;162;215;255mvalidate_record\u001b[38;2;247;197;154m(\u001b[38;2;208;208;208mrecord\u001b[38;2;247;197;154m)\u001b[38;2;75;78;83m \u001b[1m\u001b[38;2;208;208;208mis\u001b[0m\u001b[38;2;75;78;83m\u001b[48;2;15;17;21m \u001b[38;2;240;189;232mTrue\u001b[38;2;208;208;208m                 \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 23 \u001b[38;2;208;208;208m                                                                         \u001b[38;2;162;215;255m\u2502\u001b[38;2;75;78;83m~\r\n\u001b[38;2;162;215;255m\u2506 \u001b[38;2;75;78;83m 24     \u001b[1m\u001b[38;2;208;208;208mdef\u001b[0m\u001b[38;2;75;78;83m\u