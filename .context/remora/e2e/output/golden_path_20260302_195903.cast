[30.3536, "o", "\u001b[H\u001b[2J loader.py  test_loader.py\ntests/test_loader.py\n  1   \"\"\"Tests for configlib.loader.\"\"\"\n    1\n    2 from __future__ import annotations\n    3\n    4 import json\n    5 from pathlib import Path\n    6\n    7 import pytest\n    8\n    9 from configlib.loader import detect_format, load_config, load_yaml\n   10\n   11\n   12 def test_load_yaml(tmp_path: Path) -> None:\n   13     \"\"\"Test loading a YAML configuration file.\"\"\"\n   14     config_file = tmp_path / \"config.yaml\"\n   15     config_file.write_text(\"database:\\n  host: localhost\\n  port: 5432\\n\")\n   16     result = load_config(config_file)\n   17     assert result[\"database\"][\"host\"] == \"localhost\"\n   18     assert result[\"database\"][\"port\"] == 5432\n   19\n   20\n   21 def test_load_json(tmp_path: Path) -> None:\n   22     \"\"\"Test loading a JSON configuration file.\"\"\"\n   23     config_file = tmp_path / \"config.json\"\n   24     config_file.write_text(json.dumps({\"api_key\": \"test123\", \"debug\": True}))\n   25     result = load_config(config_file)\n   26     assert result[\"api_key\"] == \"test123\"\n   27\n   28\n   29 def test_detect_format() -> None:\n   30     \"\"\"Test format detection from file extensions.\"\"\"\n Normal  ~/Documents/Projects/remora/remora_demo/project/tests/test_loader.py    python utf-8[unix] 1.14KiB  1|36\u2502 1|33\n:e /home/andrew/Documents/Projects/remora/remora_demo/project/tests/test_loader.py\n"]
