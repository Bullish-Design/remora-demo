Unsupported format: {fmt}\")\n   23\n   24     validate(data)\n   25     return data\n   26\n   27\n   28 def detect_format(path: str | Path) -> str:\n   29     \"\"\"Detect config file format from extension.\"\"\"\n   30     suffix = Path(path).suffix.lower()\n   31     mapping = {\".json\": \"json\", \".yaml\": \"yaml\", \".yml\": \"yaml\", \".toml\": \"toml\"}\n Normal  src/configlib/loader.py                                                 python utf-8[unix] 1.09KiB  1|44\u2502 1|43\n\n"]
